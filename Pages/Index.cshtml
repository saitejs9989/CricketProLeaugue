@page
@model CricketLeague.Pages.IndexModel
@{ ViewData["Title"] = "Home"; }

<!-- HERO -->
<section class="hero">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <div class="hero-tag">Season 2024 · T20 League · Now Live</div>
        <h1>THE ULTIMATE<span class="hl">CRICKET</span>LEAGUE</h1>
        <p>Follow live standings, deep-dive player stats, and track every match in the most thrilling T20 competition of the year.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
          <a href="/Standings" class="btn-g d-inline-block" style="width:auto;padding:.8rem 2.2rem;">View Standings →</a>
        }
        else
        {
          <a href="/Account/Register" class="btn-g d-inline-block me-3" style="width:auto;padding:.8rem 2rem;">Get Started →</a>
          <a href="/Account/Login"    class="nav-outline d-inline-block" style="padding:.8rem 1.5rem;border-radius:8px;">Sign In</a>
        }
        <div class="hero-nums">
          <div><div class="hnum-n">@Model.TeamCount</div><div class="hnum-l">Teams</div></div>
          <div><div class="hnum-n">@Model.PlayerCount</div><div class="hnum-l">Players</div></div>
          <div><div class="hnum-n">@Model.MatchCount</div><div class="hnum-l">Matches</div></div>
        </div>
      </div>
      <div class="col-lg-6 d-none d-lg-flex justify-content-center">
        <div class="ball-wrap"><div class="ball"></div></div>
      </div>
    </div>
  </div>
</section>

@if (User.Identity?.IsAuthenticated != true)
{
  <!-- Features -->
  <section class="py-5">
    <div class="container">
      <div class="text-center mb-5"><div class="lbl">Everything You Need</div><h2 class="sec-title">BUILT FOR FANS &amp; ANALYSTS</h2></div>
      <div class="row g-4">
        @foreach (var f in new[]{("🏆","Live Standings","Real-time team rankings with W/L records, NRR, and points."),("📊","Player Stats","Full batting and bowling stats for every player in the league."),("📅","Match Tracker","Upcoming fixtures and completed match scores in one place."),("🔍","Smart Search","Find teams, players, or matches instantly with keyword search.")})
        {
          <div class="col-sm-6 col-lg-3">
            <div class="card-c text-center h-100">
              <div style="font-size:2.4rem;margin-bottom:.8rem;">@f.Item1</div>
              <h5>@f.Item2</h5>
              <p style="color:var(--muted);font-size:.88rem;margin:0;">@f.Item3</p>
            </div>
          </div>
        }
      </div>
    </div>
  </section>
}

@if (User.Identity?.IsAuthenticated == true && Model.RecentMatches.Any())
{
  <!-- Recent Matches -->
  <section class="py-5">
    <div class="container">
      <div class="d-flex justify-content-between align-items-end mb-4">
        <div><div class="lbl">Latest Results</div><h2 class="sec-title">RECENT MATCHES</h2></div>
        <a href="/Matches" class="text-g" style="font-size:.875rem;">View All →</a>
      </div>
      @foreach (var m in Model.RecentMatches)
      {
        <div class="mc">
          <div class="mc-teams">
            <div><div class="mc-team">@m.Team1?.Name</div><div class="mc-score">@m.Team1Score</div></div>
            <div class="vs-pill">VS</div>
            <div><div class="mc-team">@m.Team2?.Name</div><div class="mc-score">@m.Team2Score</div></div>
          </div>
          @if (m.Result != null){ <div class="text-center mt-2" style="font-size:.82rem;color:var(--green);">🏆 @m.Result</div> }
          <div class="text-center mt-1" style="font-size:.75rem;color:var(--muted);">📍 @m.Venue · @m.MatchDate.ToString("MMM dd, yyyy")</div>
        </div>
      }
    </div>
  </section>
}
