@page
@model CricketLeague.Pages.Account.RegisterModel
@{ ViewData["Title"] = "Register"; Layout = "_Layout"; }

<div class="auth-wrap">
  <div class="auth-box">
    <div class="text-center mb-4">
      <div style="font-size:2.8rem;">🏏</div>
      <h2>JOIN THE LEAGUE</h2>
      <p class="text-mt" style="font-size:.9rem;margin:0;">Create your account to track the action</p>
    </div>
    @if (Model.Errors.Any())
    {
      <div class="a-err">@foreach(var e in Model.Errors){<div>@e</div>}</div>
    }
    <form method="post">
      <div class="mb-3">
        <label class="form-label">Full Name</label>
        <input asp-for="FullName" class="form-control" placeholder="John Smith"/>
      </div>
      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com"/>
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters with a digit"/>
      </div>
      <div class="mb-4">
        <label class="form-label">Confirm Password</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat password"/>
      </div>
      <button type="submit" class="btn-g">Create Account →</button>
    </form>
    <hr class="divhr my-4"/>
    <p class="text-center text-mt" style="font-size:.875rem;">Already have an account? <a href="/Account/Login" class="text-g">Sign in</a></p>
  </div>
</div>
